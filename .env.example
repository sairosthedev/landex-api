# =============================================================================
# LandEx MERN Backend — environment variables
# Copy to .env and set all values before running.
# =============================================================================

# --- Application ---
NODE_ENV=development
PORT=8080
LOG_LEVEL=info
FRONTEND_BASE_URL=

# --- MongoDB (app reads MONGODB_URI only) ---
# Mirror Atlas Network Access → Allow Access from Anywhere:
MONGODB_ATLAS_NETWORK_ACCESS=0.0.0.0/0
MONGODB_ALLOW_ANY_IP=true
MONGODB_DNS_SERVERS=8.8.8.8,8.8.4.4,1.1.1.1
MONGODB_DNS_IPV4_FIRST=true
MONGODB_FAMILY=4
MONGODB_TLS=true
MONGODB_URI=
MONGODB_URI_FALLBACK=
MONGODB_SERVER_SELECTION_TIMEOUT_MS=30000

# Docker MongoDB container init only (not read by the Node app):
MONGO_ROOT_USERNAME=landex
MONGO_ROOT_PASSWORD=CHANGE_ME_mongo_password
MONGO_DATABASE=landex

# --- Redis ---
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password
CACHE_TTL_MS=3600000

# --- MinIO / S3 ---
MINIO_ROOT_USER=landex_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
OBJECT_STORAGE_PROVIDER=local
OBJECT_STORAGE_BUCKET=landex-documents
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_REGION=us-east-1

# --- Security secrets (generate strong random values) ---
JWT_SECRET=CHANGE_ME_jwt_secret_min_32_characters_long
PII_ENCRYPTION_KEY=CHANGE_ME_base64_256bit_aes_key

# --- Mail (Resend) ---
RESEND_API_KEY=
# --- Email (disabled by default — no SMTP required for dev/Vercel) ---
EMAIL_ENABLED=false
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
NOTIFICATION_FROM_EMAIL=

# --- Local volumes ---
STORAGE_BASE_PATH=./storage

# Listing photos: mongodb (free, works on Vercel) or object (S3/MinIO)
LISTING_IMAGE_STORAGE=mongodb

# Listing documents (title deed, rates, survey): mongodb (default, works on Vercel)
LISTING_DOCUMENT_STORAGE=mongodb

# KYC uploads: mongodb (default, works on Vercel) or object/local disk
KYC_DOCUMENT_STORAGE=mongodb

# --- Payments (optional) ---
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=
PAYNOW_RESULT_URL=
PAYNOW_RETURN_URL=
PAYNOW_INITIATE_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# --- SMS (optional) ---
SMS_ENABLED=false
SMS_FROM_NUMBER=
SMS_API_KEY=
SMS_API_URL=

# =============================================================================
# Set connection URLs in this file only — not in source code.
#
# Local dev: point MONGODB_URI, REDIS_HOST, OBJECT_STORAGE_* at your machine.
# Docker:    use Docker service hostnames (mongodb, redis, minio) in .env before
#            running `docker compose up`. STORAGE_BASE_PATH=/data/storage for API.
# =============================================================================
